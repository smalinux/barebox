			<0xa4	KEY_F4>,
			<0xbe	141>,
			<0xf7	KEY_F12>,
			<0xef	14>,
			<0xbd	388>;
	};

	ir_key4 {
		rockchip,usercode = <0x00ff>;
		rockchip,key_table =
			<0xf8	KEY_REPLY>,
			<0xa3	KEY_BACK>,
			<0xfc	KEY_UP>,
			<0xfd	KEY_DOWN>,
			<0xf1	KEY_LEFT>,
			<0xe5	KEY_RIGHT>,
			<0xf4	KEY_VOLUMEUP>,
			<0xa7	KEY_VOLUMEDOWN>,
			<0xeb	KEY_POWER>,
			<0xec	KEY_MENU>,
			<0xb7	KEY_HOME>,
			<0xef	KEY_F2>,
			<0xf2	KEY_F3>,
			<0x7d	141>;
	};

	ir_key5 {
		rockchip,usercode = <0xf708>;
		rockchip,key_table =
			<0x9a	KEY_REPLY>,
			<0x9c	KEY_BACK>,
			<0x9d	KEY_UP>,
			<0x97	KEY_DOWN>,
			<0x9b	KEY_LEFT>,
			<0x99	KEY_RIGHT>,
			<0x7e	KEY_VOLUMEUP>,
			<0x7d	KEY_VOLUMEDOWN>,
			<0x7f	KEY_POWER>,
			<0x98	KEY_MENU>,
			<0x9f	KEY_HOME>,
