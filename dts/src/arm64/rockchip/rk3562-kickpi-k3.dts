			<0xee	KEY_AUDIO>,
			<0xab	KEY_WWW>,
			<0xf6	KEY_VIDEO>,
			<0xb0	KEY_APPSELECT>;
	};

	ir_key8 {
		rockchip,usercode = <0x4040>;
		rockchip,key_table =
			<0xf2	KEY_REPLY>,
			<0xbd	KEY_BACK>,
			<0xf4	KEY_UP>,
			<0xf1	KEY_DOWN>,
			<0xef	KEY_LEFT>,
			<0xee	KEY_RIGHT>,
			<0xe5	KEY_HOME>,
			<0xe7	KEY_VOLUMEUP>,
			<0xe8	KEY_VOLUMEDOWN>,
			<0xb2	KEY_POWER>,
			<0xbc	KEY_MUTE>,
			<0xba	KEY_MENU>,
			<0xfe	KEY_1>,
			<0xfd	KEY_2>,
			<0xfc	KEY_3>,
			<0xfb	KEY_4>,
			<0xfa	KEY_5>,
			<0xf9	KEY_6>,
