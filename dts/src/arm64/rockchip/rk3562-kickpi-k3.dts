&i2c5 {
	status = "okay";
	gc5035_1: gc5035_1@37 {
		compatible = "galaxycore,gc5035";
		status = "okay";
		reg = <0x37>;

		clocks = <&cru CLK_CAM1_OUT2IO>;
		clock-names = "xvclk";
