	ports {
		#address-cells = <1>;
		#size-cells = <0>;

		port@1 {
			reg = <1>;
			dsi_out_panel: endpoint {
				remote-endpoint = <&panel_in_dsi>;
			};
		};
	};
};

&i2c2 {
	status = "okay";
	gt9xx:gt9xx@5d {
		compatible = "goodix,gt9xx";
		status = "okay";
		reg = <0x5d>;

		gtp_resolution_x = <800>;
		gtp_resolution_y = <1280>;
		gtp_int_tarigger = <1>;
		//gtp_change_x2y = <1>;
		//gtp_overturn_x = <1>;
		//gtp_overturn_y = <0>;
		gtp_send_cfg = <1>;
		gtp_touch_wakeup = <1>;
		goodix_rst_gpio = <&gpio0 RK_PB7 GPIO_ACTIVE_HIGH>;
		goodix_irq_gpio = <&gpio0 RK_PC3 IRQ_TYPE_LEVEL_LOW>;
		pinctrl-names = "default";
		pinctrl-0 = <&touch1_gpio>;

		goodix,cfg-group0 = [
			70 20 03 00 05 05 35 00 01 0A
			28 0F 5A 3C 03 05 00 00 00 00
			00 00 06 18 1A 1E 14 8C 2E 0E
			B0 B2 B2 04 00 00 00 98 02 1C
			00 01 00 00 00 03 64 32 00 00
			00 A0 F5 94 D5 02 07 00 00 04
			83 A7 00 7E B5 00 78 C6 00 73
			D7 00 6F EA 00 6F 00 00 00 00
			00 00 00 00 00 00 00 00 00 00
			00 00 00 00 00 00 00 00 00 00
			00 00 00 00 00 00 00 00 00 00
			00 00 1C 1A 18 16 14 12 10 0E
			0C 0A 08 06 04 02 FF FF FF FF
			FF FF FF FF FF FF FF FF FF FF
			FF FF 00 02 04 06 08 0A 0C 0F
			10 12 13 14 16 2A 29 28 26 24
			22 21 20 1F 1E 1D 1C 18 FF FF
			FF FF FF FF FF FF FF FF FF FF
			FF FF FF FF FC 01
		];

	};
};

&pinctrl {
	touch1 {
		touch1_gpio: touch-gpio {
			rockchip,pins =
				<0 RK_PC3 RK_FUNC_GPIO &pcfg_pull_none>,
				<0 RK_PB7 RK_FUNC_GPIO &pcfg_pull_none>;
		};
	};

};

&i2c4 {
	status = "okay";
	gc5035_0: gc5035_0@37 {
		compatible = "galaxycore,gc5035";
		status = "okay";
		reg = <0x37>;

		clocks = <&cru CLK_CAM0_OUT2IO>;
		clock-names = "xvclk";
		pinctrl-names = "default";
		pinctrl-0 = <&camm0_clk0_out>;
		//reset-gpios = <&gpio4 RK_PB4 GPIO_ACTIVE_HIGH>;
		//pwdn-gpios = <&gpio3 RK_PC0 GPIO_ACTIVE_HIGH>;

		reset-gpios = <&pca9554_gpio 0 GPIO_ACTIVE_HIGH>;
		pwdn-gpios = <&pca9554_gpio 7 GPIO_ACTIVE_HIGH>;

		rockchip,camera-module-index = <0>;
		rockchip,camera-module-facing = "front";
		rockchip,camera-module-name = "default";
		rockchip,camera-module-lens-name = "PC5322-M5";
		port {
			gc5035_out0: endpoint {
				remote-endpoint = <&mipi_in_ucam0>;
				data-lanes = <1 2>;
			};
		};
	};
};

&csi2_dphy0 {
	status = "okay";

	ports {
		#address-cells = <1>;
		#size-cells = <0>;
		port@0 {
			reg = <0>;
			#address-cells = <1>;
			#size-cells = <0>;

	mipi_in_ucam0: endpoint@0 {
				reg = <0>;
				remote-endpoint = <&gc5035_out0>;
				data-lanes = <1 2>;
			};
		};
		port@1 {
			reg = <1>;
			#address-cells = <1>;
			#size-cells = <0>;

			csidcphy0_out: endpoint@0 {
				reg = <0>;
				remote-endpoint = <&mipi0_csi2_input>;
			};
		};
	};
};


&mipi0_csi2 {
	status = "okay";

	ports {
		#address-cells = <1>;
		#size-cells = <0>;

		port@0 {
			reg = <0>;
			#address-cells = <1>;
			#size-cells = <0>;

			mipi0_csi2_input: endpoint@1 {
				reg = <1>;
				remote-endpoint = <&csidcphy0_out>;
			};
		};

		port@1 {
			reg = <1>;
			#address-cells = <1>;
			#size-cells = <0>;

			mipi0_csi2_output: endpoint@0 {
				reg = <0>;
				remote-endpoint = <&cif_mipi_in0>;
			};
		};
	};
};

&rkcif_mipi_lvds {
	status = "okay";

	port {
		cif_mipi_in0: endpoint {
			remote-endpoint = <&mipi0_csi2_output>;
		};
	};
};

&rkcif_mipi_lvds_sditf {
	status = "okay";

	port {
		mipi_lvds_sditf: endpoint {
			remote-endpoint = <&isp_vir0>;
		};
