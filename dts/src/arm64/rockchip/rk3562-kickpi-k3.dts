	};

	vcc3v3_pcie20: vcc3v3-pcie20 {
		compatible = "regulator-fixed";
		regulator-name = "vcc3v3_pcie20";
		regulator-min-microvolt = <3300000>;
		regulator-max-microvolt = <3300000>;
		enable-active-high;
		regulator-boot-on;
		regulator-always-on;
		gpios = <&gpio3 RK_PC5 GPIO_ACTIVE_HIGH>;
		startup-delay-us = <5000>;
		vin-supply = <&dc_12v>;
	};
};

&sdmmc1 {
	no-sd;
	no-mmc;
	bus-width = <4>;
	disable-wp;
	cap-sd-highspeed;
	cap-sdio-irq;
	keep-power-in-suspend;
	mmc-pwrseq = <&sdio_pwrseq>;
	non-removable;
	pinctrl-names = "default";
	pinctrl-0 = <&sdmmc1_bus4 &sdmmc1_cmd &sdmmc1_clk>;
	sd-uhs-sdr104;
	status = "okay";
};

&uart7 {
	status = "okay";
	pinctrl-names = "default";
	pinctrl-0 = <&uart7m0_xfer &uart7m0_ctsn>;
};

&pinctrl {
	wireless-bluetooth {
		uart7_gpios: uart7-gpios {
			rockchip,pins = <3 RK_PD3 RK_FUNC_GPIO &pcfg_pull_none>;
		};
	};

	sdio-pwrseq {
		wifi_enable_h: wifi-enable-h {
			rockchip,pins = <0 RK_PB3 RK_FUNC_GPIO &pcfg_pull_up>;
		};
	};

	wireless-wlan {
		wifi_host_wake_irq: wifi-host-wake-irq {
			rockchip,pins = <0 RK_PB4 RK_FUNC_GPIO &pcfg_pull_down>;
		};
	};
};

&pcie2x1 {
	reset-gpios = <&gpio3 RK_PB0 GPIO_ACTIVE_HIGH>;
	vpcie3v3-supply = <&vcc3v3_pcie20>;
	status = "okay";
};

&i2c5 {
	status = "okay";
	pinctrl-names = "default";
	pinctrl-0 = <&i2c5m0_xfer>;
};


&uart4 {
	status = "okay";
	pinctrl-names = "default";
	pinctrl-0 = <&uart4m0_xfer>;
};

&leds {
	gpio3c0 {
		gpios = <&gpio3 RK_PC0 GPIO_ACTIVE_HIGH>;
		default-state = "on";
	};
	gpio3c1 {
		gpios = <&gpio3 RK_PC1 GPIO_ACTIVE_HIGH>;
		default-state = "on";
	};
	gpio0a6 {
		gpios = <&gpio0 RK_PA6 GPIO_ACTIVE_HIGH>;
		default-state = "on";
	};
	gpio4b6 {
		gpios = <&gpio4 RK_PB6 GPIO_ACTIVE_HIGH>;
		default-state = "on";
	};
};

&gmac0 {
	/* Use rgmii-rxid mode to disable rx delay inside Soc */
	//phy-mode = "rgmii-rxid";
	phy-mode = "rgmii";
	clock_in_out = "output";

	snps,reset-gpio = <&gpio3 RK_PA0 GPIO_ACTIVE_LOW>;
	snps,reset-active-low;
	/* Reset time is 20ms, 100ms for rtl8211f */
	snps,reset-delays-us = <0 20000 100000>;

	tx_delay = <0x47>;
	rx_delay = <0x40>;

	pinctrl-names = "default";
	pinctrl-0 = <&rgmiim0_miim
					&rgmiim0_tx_bus2
					&rgmiim0_rx_bus2
					&rgmiim0_rgmii_clk
					&rgmiim0_rgmii_bus>;
					//&ethm0_pins>;

	phy-handle = <&rgmii_phy>;
	status = "okay";
};

&mdio0 {
	rgmii_phy: phy@1 {
		compatible = "ethernet-phy-ieee802.3-c22";
		reg = <0x1>;
		//clocks = <&cru CLK_GMAC_ETH_OUT2IO>;
		//assigned-clocks = <&cru CLK_GMAC_ETH_OUT2IO>;
		//assigned-clock-rates = <25000000>;
	};
};

&gmac1 {
	status = "okay";
	phy-mode = "rmii";
	clock_in_out = "input";

	snps,reset-gpio = <&gpio3 RK_PA1 GPIO_ACTIVE_LOW>;
	snps,reset-active-low;
	snps,reset-delays-us = <0 20000 100000>;

	tx_delay = <0x10>;
	rx_delay = <0x2f>;

	pinctrl-names="default";
	pinctrl-0 = <&rmii_pins>;

	phy-handle = <&rgmii_phy1>;
};

&mdio1 {
	rgmii_phy1: phy@1 {
		compatible = "ethernet-phy-ieee802.3-c22";
		reg = <0x01>;
	};
};

&pwm5 {
	status = "okay";
	pinctrl-0 = <&pwm5m0_pins>;
};

/*
