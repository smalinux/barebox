			<0xa4   KEY_MUTE>,
			<0x78   KEY_POWER>,
			<0x23   KEY_F4>,
			<0x0a   KEY_F5>,
			<0xba   KEY_F6>,
			<0x99   KEY_F7>;
	};

	ir_key7 {
		rockchip,usercode = <0x7f80>;
		rockchip,key_table =
			<0xf2	KEY_REPLY>,
			<0xe4	KEY_BACK>,
			<0xd9	KEY_UP>,
			<0xd7	KEY_DOWN>,
			<0xda	KEY_LEFT>,
