			<0x86   KEY_MUTE>,
			<0x87   KEY_F8>,
			<0x8d   388>,
			<0x0a   KEY_F5>,
			<0xba   KEY_F6>;
	};

	ir_key6 {
		rockchip,usercode = <0x1608>;
		rockchip,key_table =
			<0xb0   102>,    //home
			<0x74   KEY_BACK>,
			<0x75   KEY_MENU>,
			<0x4d   28>,
			<0x7b   KEY_UP>,
			<0x72   KEY_DOWN>,
			<0x44   KEY_LEFT>,
			<0x71   KEY_RIGHT>,
			<0x4a   KEY_VOLUMEDOWN>,
